# Google Sheets — add ALL of these in Vercel → Settings → Environment Variables
# (Production + Preview). Then redeploy. Share the sheet with the service account (Editor).
#
# Debug: open https://your-site.vercel.app/api/rsvp — should show {"ok":true,"missing":[]}
#
# GOOGLE_PRIVATE_KEY: paste the full key from the JSON file. Use real line breaks, or \n between lines.

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----
GOOGLE_SHEET_ID=your_spreadsheet_id_from_the_url
GOOGLE_SHEET_TAB=Sheet1

# Google Sheets (service account) — set in Vercel → Project → Settings → Environment Variables
# Share your spreadsheet with the service account email (Editor).

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your_spreadsheet_id_from_the_url
# Tab name in the spreadsheet (default: Sheet1)
GOOGLE_SHEET_TAB=Sheet1
